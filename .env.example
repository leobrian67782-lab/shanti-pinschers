# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/shanti-pinschers

# Session / JWT secret - use a long random string
SESSION_SECRET=change_this_to_a_long_random_string
JWT_SECRET=change_this_to_a_different_long_random_string

# Admin login (used only by the one-time create-admin script)
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD=ChooseAStrongPasswordHere

# Cloudinary (free tier) - REQUIRED for photo uploads to survive restarts/redeploys on Render
# Sign up free at https://cloudinary.com then copy these 3 values from your dashboard
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Brevo (formerly Sendinblue) - for sending email notifications on new inquiries
BREVO_API_KEY=
NOTIFY_EMAIL=you@example.com
SITE_NAME=Shanti Bryan Pinschers
SITE_URL=https://shantibryanpinschers.com

PORT=3000
NODE_ENV=production
