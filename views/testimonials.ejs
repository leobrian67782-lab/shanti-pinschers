<%- include('partials/header') %>

<section class="section container">
  <span class="eyebrow">From Our Families</span>
  <h1>Testimonials</h1>

  <% if (submitted) { %>
    <div class="alert alert-success">Thank you &mdash; your testimonial has been submitted and will appear here once reviewed.</div>
  <% } %>

  <% if (testimonials.length) { %>
    <div class="ledger-grid reveal-group" style="margin-bottom:48px;">
      <% testimonials.forEach(t => { %>
        <div class="testimonial-card">
          <div class="testimonial-stars"><%= '★'.repeat(t.rating) %></div>
          <p>&ldquo;<%= t.message %>&rdquo;</p>
          <div class="testimonial-name"><%= t.name %></div>
          <div class="testimonial-loc"><%= t.location || '' %><%= t.puppyName ? ' · took home ' + t.puppyName : '' %></div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="empty-state" style="margin-bottom:48px;">No testimonials published yet.</div>
  <% } %>

  <div class="form-card">
    <h2 style="font-size:20px;">Share Your Experience</h2>
    <p style="font-size:13px; color:var(--muted); margin-bottom:16px;">Submitted testimonials are reviewed before publishing.</p>
    <form method="POST" action="/testimonials">
      <div class="field"><label>Your Name</label><input type="text" name="name" required /></div>
      <div class="field-row">
        <div class="field"><label>Location (optional)</label><input type="text" name="location" /></div>
        <div class="field"><label>Puppy's Name (optional)</label><input type="text" name="puppyName" /></div>
      </div>
      <div class="field">
        <label>Rating</label>
        <select name="rating">
          <option value="5">5 - Excellent</option>
          <option value="4">4 - Great</option>
          <option value="3">3 - Good</option>
        </select>
      </div>
      <div class="field"><label>Your Testimonial</label><textarea name="message" required></textarea></div>
      <button type="submit" class="btn btn-primary">Submit Testimonial</button>
    </form>
  </div>
</section>

<%- include('partials/footer') %>
