<%- include('partials/header') %>

<section class="section container">
  <span class="eyebrow">The Nursery</span>
  <h1>Litters</h1>
  <p style="color:var(--muted); max-width:560px;">Expected, newborn, and recently weaned litters. Each litter carries its own ledger number for reference when you inquire.</p>

  <% if (litters.length) { %>
    <div class="ledger-grid">
      <% litters.forEach(litter => { %>
        <div class="ledger-card">
          <div class="ledger-card-photo">
            <% if (litter.photos && litter.photos.length) { %>
              <img src="<%= litter.photos[0].url %>" alt="<%= litter.title %>" loading="lazy" />
            <% } else { %>
              <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; color:#999; font-size:13px;">No photo yet</div>
            <% } %>
            <span class="ledger-no"><%= litter.ledgerNo %></span>
          </div>
          <div class="ledger-card-body">
            <h3><%= litter.title %></h3>
            <div class="ledger-meta">
              Sire: <%= litter.sireName %> &middot; Dam: <%= litter.damName %><br/>
              <% if (litter.dob) { %>Born <%= new Date(litter.dob).toLocaleDateString() %><% } else if (litter.expectedDate) { %>Expected <%= new Date(litter.expectedDate).toLocaleDateString() %><% } %>
            </div>
            <% if (litter.description) { %><p style="font-size:14px; margin-top:8px;"><%= litter.description %></p><% } %>
            <div class="ledger-price" style="text-transform:capitalize;">Status: <%= litter.status %></div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } else { %>
    <div class="empty-state">No litters posted yet. <a href="/contact">Contact us</a> to be notified of upcoming litters.</div>
  <% } %>
</section>

<%- include('partials/footer') %>
